# QuantBet-EV 环境变量模板
# 开发: 复制为 .env，保持 APP_ENV=development (SQLite, 无认证)
# 生产: 复制 .env.prod，修改 API_TOKEN 和 DB_PASSWORD

# development | production | test
APP_ENV=development

# 仅 production 需要
DB_PASSWORD=quantbet_dev
API_TOKEN=your-secret-token-here
DATABASE_URL=postgresql://quantbet:quantbet_dev@localhost:5432/quantbet

# 只读副本 (可选, 生产环境用于读写分离)
DATABASE_URL_READ_ONLY=
